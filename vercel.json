{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd wacrm && npm run build",
  "installCommand": "cd wacrm && npm install",
  "outputDirectory": "wacrm/.next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/wacrm/api/tasks/reminders/cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/wacrm/api/appointments/reminders/cron",
      "schedule": "*/30 * * * *"
    }
  ]
}
